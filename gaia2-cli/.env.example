# Copy this file to .env and fill only the values you need.
# The runner auto-loads gaia2-cli/.env by default.
# Shell environment variables still take precedence.
# Keep judge provider / model / base URL / API key in TOML or CLI, not here.

# Agent provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPLETIONS_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
API_KEY=

# Optional Hugging Face auth for dataset download
HF_TOKEN=

# Optional outbound proxy / TLS for provider or Hugging Face access
GAIA2_PROXY_RELAY_URL=
GAIA2_CA_BUNDLE=
http_proxy=
https_proxy=
HTTP_PROXY=
HTTPS_PROXY=
no_proxy=localhost,127.0.0.1,::1
NO_PROXY=localhost,127.0.0.1,::1
